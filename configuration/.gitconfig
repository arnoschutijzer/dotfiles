# This is Git's per-user configuration file.
# Fallback identity for tools (e.g. Xcode) that don't evaluate includeIf.
# The includeIf blocks below override this for matching directories.
[user]
	name = Arno Schutijzer
	email = arno.schutijzer@protonmail.com
[core]
	excludesfile = /Users/arnoschutijzer/.gitignore_global
	pager = delta
[push]
	autoSetupRemote = true
[pull]
	ff = only
[init]
	defaultBranch = main
[commit]
	gpgsign = true
[branch]
	autosetuprebase = always
[alias]
	praise = blame
	fixup = commit --amend --no-edit
	prune-gone = !git fetch -p && git branch -vv | awk '/: gone]/{print $1}' | xargs -r git branch -D
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[includeIf "gitdir:~/"]
    path = ~/.gitconfig-personal
[includeIf "gitdir:~/development/skryv/"]
    path = ~/.gitconfig-work
[includeIf "gitdir:~/development/enohealth/"]
    path = ~/.gitconfig-eno
[url "ssh://git@github.com/"]
    insteadOf = https://github.com/
[rerere]
	enabled = true
