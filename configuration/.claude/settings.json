{
  "model": "opus",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "terraform-code-generation@hashicorp": true,
    "terraform-module-generation@hashicorp": true,
    "github@claude-plugins-official": true
  }
}
